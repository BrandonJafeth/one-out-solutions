---
import NavbarMobile from './NavbarMobile';
---

<header class="fixed top-0 inset-x-0 z-50 bg-black border-b border-[rgba(214,235,253,0.19)] transition-all duration-300">
  <div class="max-w-[1400px] mx-auto px-6 h-20 flex items-center justify-between">
    
    <a href="#" class="font-display font-bold text-xl tracking-tight text-[#f0f0f0] flex items-center gap-2 group">
      ONE OUT <span class="text-[#a1a4a5] group-hover:text-[#f0f0f0] transition-colors duration-500">SOLUTIONS.</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-12">
      <div class="flex items-center gap-8">
        {[
          { name: 'Nosotros', href: '#nosotros' },
          { name: 'Servicios', href: '#servicios' },
          { name: 'Proceso', href: '#proceso' },
          { name: 'Proyectos', href: '#proyectos' },
        ].map((link) => (
          <a 
            href={link.href} 
            class="font-sans text-[14px] font-medium tracking-[0.35px] text-[#a1a4a5] hover:text-[#f0f0f0] transition-all duration-300"
            style="font-feature-settings: 'ss01', 'ss03', 'ss04'"
          >
            {link.name}
          </a>
        ))}
      </div>
      
      <a href="#contacto" class="bg-white text-black text-[14px] font-medium tracking-[0.35px] py-[5px] px-[12px] rounded-full hover:bg-white/90 transition-all duration-300" style="font-feature-settings: 'ss01', 'ss03', 'ss04'">
        Iniciar Crecimiento
      </a>
    </nav>

    <!-- Mobile Nav (React Island) -->
    <NavbarMobile client:idle />
    
  </div>
</header>
