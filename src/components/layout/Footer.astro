---
const currentYear = new Date().getFullYear();
---

<footer class="bg-black border-t border-white/5 pt-24 pb-12 relative overflow-hidden">
  <!-- Subtle lighting -->
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full pointer-events-none translate-x-1/2 translate-y-1/2" style="background: radial-gradient(circle at center, rgba(219,105,35,0.05) 0%, transparent 60%);"></div>

  <div class="max-w-[1400px] mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 mb-24">
      <div class="lg:col-span-6">
        <a href="#" class="font-display font-bold text-3xl tracking-[-0.08em] text-white flex items-center gap-3 mb-8 group">
          <div class="w-3 h-3 rounded-full bg-orange transition-all duration-500 group-hover:bg-white group-hover:shadow-[0_0_15px_rgba(255,255,255,0.4)]"></div>
          ONE OUT <span class="text-silver hover:text-white transition-colors duration-500">SOLUTIONS.</span>
        </a>
        <p class="text-silver text-lg font-light max-w-md leading-relaxed mb-10">
          Transformamos ambiciones empresariales en infraestructuras digitales dominantes. Tu socio estratégico en ingeniería de crecimiento.
        </p>
        <div class="flex gap-6">
          <a href="#contacto" class="pill-cta pill-cta-primary px-10 py-3.5 text-sm font-bold tracking-widest">EMPEZAR AHORA</a>
        </div>
      </div>
      
      <div class="lg:col-span-3">
        <h4 class="font-display text-white font-bold tracking-[0.2em] uppercase text-[10px] mb-8 border-l-2 border-orange pl-4">MAPA ESTRATÉGICO</h4>
        <ul class="space-y-4">
          <li><a href="#nosotros" class="text-silver hover:text-white hover:tracking-widest transition-all duration-300 font-light">Estrategia</a></li>
          <li><a href="#servicios" class="text-silver hover:text-white hover:tracking-widest transition-all duration-300 font-light">Sistemas</a></li>
          <li><a href="#proceso" class="text-silver hover:text-white hover:tracking-widest transition-all duration-300 font-light">Metodología</a></li>
          <li><a href="#planes" class="text-silver hover:text-white hover:tracking-widest transition-all duration-300 font-light">Inversión</a></li>
        </ul>
      </div>
      
      <div class="lg:col-span-3">
        <h4 class="font-display text-white font-bold tracking-[0.2em] uppercase text-[10px] mb-8 border-l-2 border-orange pl-4">NÚCLEO DE CONTROL</h4>
        <ul class="space-y-4">
          <li class="text-silver font-light">HQ: Costa Rica, Global Operations</li>
          <li><a href="mailto:info@oneoutsolutions.com" class="text-silver hover:text-orange transition-colors font-light">info@oneoutsolutions.com</a></li>
        </ul>
      </div>
    </div>
    
    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="text-silver/60 text-[10px] tracking-[0.2em] font-medium uppercase">&copy; {currentYear} ONE OUT SOLUTIONS engineering. All rights reserved.</p>
      <div class="flex gap-10">
        <a href="#" class="text-silver hover:text-white transition-colors text-[10px] font-bold tracking-[0.2em] uppercase">LinkedIn</a>
        <a href="#" class="text-silver hover:text-white transition-colors text-[10px] font-bold tracking-[0.2em] uppercase">GitHub</a>
        <a href="#" class="text-silver hover:text-white transition-colors text-[10px] font-bold tracking-[0.2em] uppercase">Behance</a>
      </div>
    </div>
  </div>
</footer>
