---
const currentYear = new Date().getFullYear();
---

<footer class="bg-black border-t border-border pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
    <div class="md:col-span-2">
      <a href="#" class="font-display font-bold text-3xl tracking-tighter text-white mb-6 inline-block">
        ONE OUT.
      </a>
      <p class="text-muted max-w-sm">
        Desarrollo de software y soluciones tecnológicas agresivas para empresas que exigen liderazgo en la era digital.
      </p>
    </div>
    
    <div>
      <h4 class="font-display text-white font-bold tracking-widest uppercase text-sm mb-6">Mapa del Sitio</h4>
      <ul class="space-y-4">
        <li><a href="#nosotros" class="text-muted hover:text-orange transition-colors">Nosotros</a></li>
        <li><a href="#servicios" class="text-muted hover:text-orange transition-colors">Servicios</a></li>
        <li><a href="#proceso" class="text-muted hover:text-orange transition-colors">Proceso</a></li>
        <li><a href="#planes" class="text-muted hover:text-orange transition-colors">Planes</a></li>
      </ul>
    </div>
    
    <div>
      <h4 class="font-display text-white font-bold tracking-widest uppercase text-sm mb-6">Contacto</h4>
      <ul class="space-y-4">
        <li class="text-muted">Costa Rica</li>
        <li><a href="mailto:info@oneoutsolutions.com" class="text-muted hover:text-orange transition-colors">info@oneoutsolutions.com</a></li>
      </ul>
    </div>
  </div>
  
  <div class="max-w-7xl mx-auto px-6 pt-8 border-t border-border flex flex-col md:flex-row items-center justify-between gap-4">
    <p class="text-muted text-sm">&copy; {currentYear} One Out Solutions. Todos los derechos reservados.</p>
    <div class="flex gap-4">
      {/* Social links placeholder */}
      <a href="#" class="text-muted hover:text-white transition-colors" aria-label="LinkedIn">IN</a>
      <a href="#" class="text-muted hover:text-white transition-colors" aria-label="GitHub">GH</a>
    </div>
  </div>
</footer>
