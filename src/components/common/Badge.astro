---
interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<div class={`inline-flex items-center gap-2 px-3 py-1 font-display text-xs tracking-[0.2em] uppercase font-bold text-cyan border border-border bg-surface rounded-full ${className}`}>
  <span class="w-1.5 h-1.5 rounded-full bg-cyan animate-pulse"></span>
  <slot />
</div>
