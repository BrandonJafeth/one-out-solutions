---
interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<div class={`inline-flex items-center gap-3 px-4 py-1.5 font-display text-[10px] tracking-[0.3em] uppercase font-bold text-white border border-white/10 bg-white/5 rounded-full backdrop-blur-md ${className}`}>
  <div class="relative flex h-2 w-2">
    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange opacity-75"></span>
    <span class="relative inline-flex rounded-full h-2 w-2 bg-orange"></span>
  </div>
  <slot />
</div>
