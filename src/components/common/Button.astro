---
interface Props {
  href: string;
  variant?: 'primary' | 'outline';
  className?: string;
}

const { href, variant = 'primary', className = '' } = Astro.props;

const baseStyles = "inline-flex items-center justify-center font-display font-bold text-sm tracking-widest uppercase py-3 px-6 transition-all duration-300 ease-out z-[1] relative overflow-hidden group";

const variants = {
  primary: "bg-orange text-white border border-transparent hover:border-orange hover:bg-black",
  outline: "bg-transparent text-orange border border-orange hover:bg-orange hover:text-white"
};
---

<a href={href} class={`${baseStyles} ${variants[variant]} ${className}`}>
  <!-- Botones animado -->
  <span class="relative z-10">{<slot />}</span>
  {variant === 'primary' && (
     <div class="absolute inset-0 h-full w-full bg-black -translate-x-full transition-transform duration-300 ease-out group-hover:translate-x-0 z-0"></div>
     <span class="relative z-10 pointer-events-none group-hover:text-orange transition-colors duration-300"><slot /></span>
  )}
</a>

<style>
  a {
    /* Hide the direct standard slot if primary to prevent double text */
  }
  a.bg-orange > span:first-of-type {
    display: none;
  }
  a.bg-transparent > span:last-of-type {
    display: none;
  }
</style>
