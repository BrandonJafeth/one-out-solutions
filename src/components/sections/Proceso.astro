---
import Badge from '../common/Badge.astro';
import proceso from '../../data/proceso.json';
import { Search, PencilRuler, Code2, Rocket } from 'lucide-react';

const IconMap = {
  Search,
  PencilRuler,
  Code2,
  Rocket
};
---

<section id="proceso" class="py-32 bg-surface">
  <div class="max-w-4xl mx-auto px-6">
    <div class="text-center mb-24 section-header">
      <Badge className="mb-6">Cómo Trabajamos</Badge>
      <h2 class="font-display font-bold text-3xl md:text-4xl tracking-tight">
        METODOLOGÍA DE <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange to-cyan">PRESCISIÓN</span>
      </h2>
    </div>

    <div class="relative wrap-proceso">
      <!-- Linea base -->
      <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-border -translate-x-1/2 z-0 scale-y-0 transform origin-top timeline-line"></div>

      <div class="space-y-16 lg:space-y-24 relative z-10">
        {proceso.map((p, index) => {
          const isEven = index % 2 === 1;
          const IconComponent = IconMap[p.icon as keyof typeof IconMap];
          
          return (
            <div class="timeline-item flex flex-col md:flex-row items-center gap-8 w-full opacity-0 translate-y-12">
              <div class={`w-full md:w-1/2 ${isEven ? 'md:order-3 md:pl-16' : 'md:text-right md:pr-16'}`}>
                <div class={`inline-block mb-4 p-3 bg-black rounded-xl text-cyan`}>
                  {IconComponent && <IconComponent size={28} />}
                </div>
                <h3 class="font-display font-bold text-2xl mb-3 text-white flex items-center gap-3">
                  {isEven ? '' : <span class="text-border text-lg md:hidden">0{index + 1}</span>}
                  {p.title}
                  {isEven ? <span class="text-border text-lg md:hidden">0{index + 1}</span> : ''}
                </h3>
                <p class="text-muted leading-relaxed">{p.description}</p>
              </div>

              <div class="hidden md:flex flex-shrink-0 w-16 h-16 rounded-full bg-black border-2 border-border text-white items-center justify-center font-display font-bold text-xl z-10 transition-colors duration-500 timeline-circle">
                {p.step}
              </div>

              <div class={`w-full md:w-1/2 ${isEven ? 'md:order-1' : ''}`}></div>
            </div>
          )
        })}
      </div>
    </div>
  </div>
</section>
