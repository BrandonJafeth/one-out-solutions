---
import Badge from '../common/Badge.astro';
import proceso from '../../data/proceso.json';
import { Search, PencilRuler, Code2, Rocket } from 'lucide-react';

const IconMap = {
  Search,
  PencilRuler,
  Code2,
  Rocket
};
---

<section id="proceso" class="py-24 md:py-40 bg-black relative overflow-hidden">
  <!-- Subtle lighting -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full pointer-events-none translate-x-1/3 -translate-y-1/3" style="background: radial-gradient(circle at center, rgba(219,105,35,0.08) 0%, transparent 60%);"></div>

  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-32 section-header">
      <Badge className="mb-10 text-orange bg-orange/5 border-orange/10">TU MAPA AL ÉXITO</Badge>
      <h2 class="font-display font-bold text-4xl md:text-7xl leading-[1.1] md:leading-[0.9] tracking-[-0.04em] md:tracking-[-0.07em]">
        ASÍ MULTIPLICAMOS <br/> <span class="text-white italic">TU NEGOCIO.</span>
      </h2>
    </div>

    <div class="relative wrap-proceso space-y-12 md:space-y-0">
      <!-- Vertical line (desktop only) -->
      <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-white/10 -translate-x-1/2 z-0 timeline-line scale-y-100 origin-top"></div>

      <div class="space-y-12 md:space-y-16 relative z-10">
        {proceso.map((p, index) => {
          const isEven = index % 2 === 1;
          const IconComponent = IconMap[p.icon as keyof typeof IconMap];
          
          return (
            <div class="timeline-item relative flex flex-col md:flex-row items-center w-full group py-4 md:py-6">
              <!-- Content side -->
              <div class={`w-full md:w-1/2 ${isEven ? 'md:ml-auto md:pl-12 lg:pl-16 text-left' : 'md:mr-auto md:pr-12 lg:pr-16 md:text-right text-left'}`}>
                <div class={`inline-flex items-center gap-4 mb-4 ${isEven ? 'flex-row' : 'md:flex-row-reverse'}`}>
                   <div class="p-3 bg-white/5 rounded-xl text-orange ring-1 ring-white/10 group-hover:bg-white/10 transition-all transform group-hover:scale-110">
                    {IconComponent && <IconComponent size={24} strokeWidth={1.5} />}
                  </div>
                  <span class="font-display text-3xl font-bold text-orange/30 group-hover:text-orange transition-colors duration-500">0{index + 1}</span>
                </div>
                
                <h3 class={`font-display font-bold text-2xl md:text-3xl tracking-[-0.04em] mb-3 text-white group-hover:text-white transition-colors ${!isEven ? 'md:ml-auto' : ''}`}>
                  {p.title}
                </h3>
                <p class={`text-silver/60 text-base md:text-lg font-light leading-relaxed max-w-md ${!isEven ? 'md:ml-auto md:mr-0' : ''}`}>
                  {p.description}
                </p>
              </div>

              <!-- Center indicator (Absolute for perfect alignment with line) -->
              <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-black border border-white/20 items-center justify-center z-10">
                <div class="w-2 h-2 rounded-full bg-orange group-hover:shadow-[0_0_12px_4px_rgba(219,105,35,0.7)] transition-shadow duration-300"></div>
              </div>
            </div>
          )
        })}
      </div>
    </div>
  </div>
</section>
