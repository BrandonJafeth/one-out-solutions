---
import Badge from '../common/Badge.astro';
import proceso from '../../data/proceso.json';
import { Search, PencilRuler, Code2, Rocket } from 'lucide-react';

const IconMap = {
  Search,
  PencilRuler,
  Code2,
  Rocket
};
---

<section id="proceso" class="py-24 md:py-40 bg-black relative overflow-hidden">
  <!-- Subtle lighting -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-cyan/5 blur-[120px] rounded-full pointer-events-none translate-x-1/3 -translate-y-1/3"></div>

  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-32 section-header">
      <Badge className="mb-10 text-cyan bg-cyan/5 border-cyan/10">THE METHODOLOGY</Badge>
      <h2 class="font-display font-bold text-4xl md:text-7xl leading-[1.1] md:leading-[0.9] tracking-[-0.04em] md:tracking-[-0.07em]">
        MAPA DE RUTA <br/> <span class="text-white italic">AL DOMINIO.</span>
      </h2>
    </div>

    <div class="relative wrap-proceso space-y-12 md:space-y-0">
      <!-- Vertical line (desktop only) -->
      <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-white/10 -translate-x-1/2 z-0 timeline-line scale-y-100 origin-top"></div>

      <div class="space-y-16 md:space-y-32 relative z-10">
        {proceso.map((p, index) => {
          const isEven = index % 2 === 1;
          const IconComponent = IconMap[p.icon as keyof typeof IconMap];
          const isTechnical = p.title.includes('Ingeniería') || p.title.includes('Despliegue');
          const accentColor = isTechnical ? 'text-cyan' : 'text-orange';
          const glowClass = isTechnical ? 'bg-cyan' : 'bg-orange';
          
          return (
            <div class="timeline-item flex flex-col md:flex-row items-center gap-12 md:gap-24 w-full group">
              <!-- Content side -->
              <div class={`w-full md:w-1/2 ${isEven ? 'md:order-3' : 'md:text-right text-left'}`}>
                <div class={`inline-flex items-center gap-4 mb-6 ${isEven ? 'flex-row' : 'md:flex-row-reverse'}`}>
                   <div class={`p-4 bg-white/5 rounded-2xl ${accentColor} ring-1 ring-white/10 group-hover:bg-white/10 transition-all transform group-hover:scale-110`}>
                    {IconComponent && <IconComponent size={32} strokeWidth={1.5} />}
                  </div>
                  <span class={`font-display text-4xl font-bold ${isTechnical ? 'text-cyan/30 group-hover:text-cyan' : 'text-orange/30 group-hover:text-orange'} transition-colors duration-500`}>0{index + 1}</span>
                </div>
                
                <h3 class="font-display font-bold text-3xl md:text-4xl tracking-[-0.04em] mb-4 text-white group-hover:text-white transition-colors">
                  {p.title}
                </h3>
                <p class="text-silver/60 text-lg md:text-xl font-light leading-relaxed max-w-lg mx-auto md:mx-0">
                  {p.description}
                </p>
              </div>

              <!-- Center indicator -->
              <div class="hidden md:flex flex-shrink-0 w-8 h-8 rounded-full bg-black border border-white/20 items-center justify-center z-10 relative">
                <div class={`w-2 h-2 rounded-full ${glowClass} animate-pulse`}></div>
                <div class={`absolute inset-0 ${glowClass}/20 blur-md rounded-full opacity-0 group-hover:opacity-100 transition-opacity`}></div>
              </div>

              <!-- Empty side to balance -->
              <div class={`hidden md:block w-full md:w-1/2 ${isEven ? 'md:order-1' : ''}`}></div>
            </div>
          )
        })}
      </div>
    </div>
  </div>
</section>
