---
import Badge from "../common/Badge.astro";
import Radar from "../ui/Radar";
---

<section
  id="hero"
  class="relative min-h-[70vh] md:min-h-[95vh] w-full flex items-center overflow-hidden bg-black hero-section border-b border-[rgba(214,235,253,0.19)]"
>
  <!-- Cinematic Film Grain Overlay -->
  <div class="noise"></div>

  <!-- Background Radar (Extreme Right Tactical Anchor - Hidden on Mobile) -->
  <div
    class="hidden md:block absolute -top-[10%] -bottom-[10%] left-[10%] lg:left-[20%] w-[140%] lg:w-[120%] z-0 opacity-60 hero-radar pointer-events-none"
    style="mask-image: radial-gradient(circle at center, black 0%, transparent 65%); -webkit-mask-image: radial-gradient(circle at center, black 0%, transparent 65%);"
  >
    <Radar
      speed={0.4}
      scale={0.85}
      ringCount={18}
      spokeCount={12}
      ringThickness={0.015}
      spokeThickness={0.005}
      sweepSpeed={0.5}
      sweepWidth={1.8}
      sweepLobes={1}
      color="#DB6923"
      backgroundColor="#000000"
      falloff={1.4}
      brightness={0.9}
      enableMouseInteraction={true}
      mouseInfluence={0.05}
      client:idle
    />
  </div>

  <!-- Cinematic Ambient Glow -->
  <div
    class="absolute inset-0 z-[1] pointer-events-none bg-[radial-gradient(circle_at_20%_40%,rgba(219,105,35,0.05),transparent_60%)]"
  >
  </div>

  <!-- Scanner Line (The Reveal Mechanism) -->
  <div
    class="absolute top-0 left-0 w-full h-0.5 bg-orange/80 shadow-[0_0_20px_rgba(219,105,35,0.8),_inset_0_0_2px_rgba(255,255,255,0.6)] z-[50] opacity-0 scan-line"
  >
  </div>

  <!-- Scanner Reveal Mask (Pure Black Overlay) -->
  <div class="absolute inset-0 bg-black z-40 hero-mask"></div>

  <div
    class="max-w-[1300px] mx-auto px-6 md:px-8 relative z-10 w-full pt-32 pb-20 md:py-32"
  >
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 md:gap-16 items-center">
      <!-- Main Content [Full Width Adaptive] -->
      <div
        class="lg:col-span-12 xl:col-span-11 flex flex-col justify-center text-left"
      >
        <h1
          class="font-display font-black tracking-[-0.04em] md:tracking-[-0.08em] text-white mb-10 md:mb-12 pointer-events-none flex flex-col text-left"
        >
          <div class="overflow-hidden py-1">
            <span
              class="inline-block translate-y-full headline-reveal text-[clamp(2.5rem,11.5vw,8rem)] leading-[1.0] md:leading-[0.85]"
              >ESCALAMOS</span
            >
          </div>
          <div class="overflow-hidden py-1">
            <span
              class="inline-block translate-y-full headline-reveal text-[clamp(2rem,9vw,6rem)] text-orange italic leading-[1.0] md:leading-[0.85]"
              >SIN LÍMITES.</span
            >
          </div>
        </h1>

        <div class="overflow-hidden mb-14 md:mb-20">
          <p
            class="text-white/80 md:text-2xl text-lg max-w-3xl font-light leading-relaxed translate-y-full text-reveal text-left opacity-90"
          >
            Diseñamos arquitecturas digitales que no solo funcionan, sino que
            conquistan.
            <span class="text-orange font-bold">Ingeniería</span> y estrategia para
            marcas que no aceptan menos que el <span
              class="text-white font-bold">dominio absoluto</span
            >.
          </p>
        </div>

        <div
          class="flex flex-col sm:flex-row items-center gap-6 md:gap-10 translate-y-full cta-reveal"
        >
          <a href="#contacto" class="relative group w-full sm:w-auto">
            <div
              class="absolute -inset-1 rounded-[9999px] transition-opacity duration-500 opacity-60 group-hover:opacity-100 pointer-events-none" style="box-shadow: 0 0 20px rgba(219,105,35,0.4);"
            >
            </div>
            <button
              class="pill-cta w-full sm:w-auto bg-orange text-white font-bold text-xs md:text-sm px-8 md:px-12 py-3.5 md:py-4 relative z-10 hover:bg-black hover:text-orange hover:ring-1 hover:ring-orange/50 transition-colors duration-300 tracking-[0.2em] rounded-[9999px]"
            >
              INICIAR ESTRATEGIA
            </button>
          </a>
          <a
            href="#servicios"
            class="font-display text-[10px] md:text-xs font-bold tracking-[0.3em] text-white/50 hover:text-white transition-colors flex items-center justify-center sm:justify-start gap-4 md:gap-6 group py-4 w-full sm:w-auto"
          >
            VER METODOLOGÍA
            <span
              class="w-8 md:w-10 h-px bg-white/20 group-hover:w-12 md:group-hover:w-16 group-hover:bg-orange/60 transition-all duration-500"
            ></span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Perspective Ambient Overlay -->
<div
  class="absolute inset-0 pointer-events-none z-[5] bg-gradient-to-t from-black via-transparent to-black opacity-80"
>
</div>

<script>
  import gsap from "gsap";

  document.addEventListener("astro:page-load", () => {
    const hero = document.querySelector(".hero-section");
    if (!hero) return;

    const tl = gsap.timeline({
      defaults: { ease: "expo.out" },
    });

    gsap.set(".hero-mask", { scaleY: 1, originY: 0 });

    tl.to(".scan-line", {
      opacity: 1,
      duration: 0.2,
    })
      .to(
        ".scan-line",
        {
          y: "100vh",
          duration: 1.8,
          ease: "power4.inOut",
        },
        "start",
      )
      .to(
        ".hero-mask",
        {
          scaleY: 0,
          duration: 1.8,
          ease: "power4.inOut",
        },
        "start",
      )
      .to(
        ".headline-reveal",
        {
          y: 0,
          stagger: 0.08,
          duration: 1.5,
        },
        "start+=0.8",
      )
      .to(
        ".text-reveal",
        {
          y: 0,
          duration: 1.2,
        },
        "start+=1.3",
      )
      .to(
        ".cta-reveal",
        {
          y: 0,
          duration: 1.2,
        },
        "start+=1.5",
      )
      .to(".scan-line", {
        opacity: 0,
        duration: 0.4,
      });

    tl.set(".scan-line", { display: "none" });
  });
</script>

<style>
  .hero-radar {
    /* High-precision rendering */
  }

  /* Optimized character rendering */
  .headline-reveal {
    backface-visibility: hidden;
    -webkit-font-smoothing: antialiased;
  }
</style>
