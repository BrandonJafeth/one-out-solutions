---
import Badge from '../common/Badge.astro';
import Radar from '../ui/Radar';
---

<section id="hero" class="relative min-h-[95vh] w-full flex items-center overflow-hidden bg-black hero-section border-b border-white/5">
  
  <!-- Cinematic Film Grain Overlay -->
  <div class="noise"></div>

  <!-- Background Radar (Subtler and better scaled) -->
  <div class="absolute inset-0 z-0 opacity-0 hero-radar pointer-events-none">
    <Radar 
      speed={0.25}
      scale={0.75}
      ringCount={16}
      spokeCount={12}
      ringThickness={0.015}
      spokeThickness={0.003}
      sweepSpeed={0.4}
      sweepWidth={1.5}
      sweepLobes={1}
      color="#DB6923"
      backgroundColor="#000000"
      falloff={1.1}
      brightness={0.8}
      enableMouseInteraction={true}
      mouseInfluence={0.04}
      client:load
    />
  </div>

  <!-- Scanner Line (The Reveal Mechanism) -->
  <div class="absolute top-0 left-0 w-full h-[1px] bg-orange/80 shadow-[0_0_20px_rgba(219,105,35,0.6)] z-[50] opacity-0 scan-line">
    <div class="absolute inset-0 bg-white/40 blur-[1px]"></div>
  </div>

  <!-- Scanner Reveal Mask (Pure Black Overlay) -->
  <div class="absolute inset-0 bg-black z-40 hero-mask"></div>

  <div class="max-w-[1300px] mx-auto px-6 md:px-8 relative z-10 w-full py-12 md:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 md:gap-16 items-center">
      
      <!-- Main Content [7/12] -->
      <div class="lg:col-span-7 xl:col-span-8 flex flex-col justify-center text-left">
        <div class="hero-reveal-wrap overflow-hidden mb-6">
          <Badge className="border-border/30 bg-white/5 text-near-white backdrop-blur-md translate-y-full badge-reveal py-1.5 px-4 text-[10px] font-bold">
            GROWTH ENGINEERING ENGINE
          </Badge>
        </div>

        <h1 class="font-display font-black tracking-[-0.04em] md:tracking-[-0.08em] text-white mb-8 pointer-events-none flex flex-col text-left">
          <div class="overflow-hidden py-1">
            <span class="inline-block translate-y-full headline-reveal text-[clamp(2rem,11vw,6.5rem)] leading-[1.1] md:leading-[0.85]">ESCALAMOS</span>
          </div>
          <div class="overflow-hidden py-1">
            <span class="inline-block translate-y-full headline-reveal text-[clamp(1.5rem,8vw,4.8rem)] text-orange italic leading-[1.1] md:leading-[0.85]">SIN LÍMITES.</span>
          </div>
        </h1>

        <div class="overflow-hidden mb-12">
          <p class="text-white/80 md:text-xl text-lg max-w-xl font-light leading-relaxed translate-y-full text-reveal text-left">
            Diseñamos arquitecturas digitales que no solo funcionan, sino que conquistan. 
            <span class="text-cyan-glow font-medium">Ingeniería</span> y estrategia para marcas que no aceptan menos que el <span class="text-white font-medium italic underline decoration-orange/40 decoration-2 underline-offset-4">dominio absoluto</span>.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row items-center gap-8 translate-y-full cta-reveal">
          <a href="#contacto" class="relative group w-full sm:w-auto">
            <div class="absolute -inset-1 bg-orange/20 rounded-full blur-sm group-hover:bg-orange/40 transition-all duration-500 animate-pulse"></div>
            <button class="pill-cta w-full sm:w-auto bg-orange text-white font-bold text-sm px-10 py-5 relative z-10 hover:bg-black hover:ring-1 hover:ring-orange/50 transition-all duration-300 tracking-[0.2em]">
              INICIAR ESTRATEGIA
            </button>
          </a>
          <a href="#servicios" class="font-display text-xs font-bold tracking-[0.3em] text-white/50 hover:text-white transition-colors flex items-center gap-6 group py-4">
            VER METODOLOGÍA
            <span class="w-10 h-px bg-white/20 group-hover:w-16 group-hover:bg-orange/60 transition-all duration-500"></span>
          </a>
        </div>
      </div>

      <!-- Live Signal Stats [5/12] -->
      <div class="lg:col-span-5 xl:col-span-4 hidden lg:flex flex-col gap-5 items-end">
        <div class="stats-reveal opacity-0 translate-x-6">
          <div class="bg-white/[0.03] border border-white/5 backdrop-blur-3xl px-6 py-5 rounded-xl w-56 group hover:bg-white/[0.05] transition-colors">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-1 h-1 rounded-full bg-orange animate-ping"></div>
              <span class="text-[9px] tracking-[0.2em] text-silver/50 uppercase font-bold">STATUS: SCANNING</span>
            </div>
            <p class="font-display text-2xl font-bold text-white tracking-tight">98.2% <span class="text-silver/40 text-sm ml-1 font-medium">ROI</span></p>
          </div>
        </div>
        <div class="stats-reveal opacity-0 translate-x-6">
          <div class="bg-white/[0.03] border border-white/5 backdrop-blur-3xl px-6 py-5 rounded-xl w-48 group hover:bg-white/[0.05] transition-colors">
             <div class="flex items-center gap-2 mb-3">
              <div class="w-1 h-1 rounded-full bg-cyan animate-pulse"></div>
              <span class="text-[9px] tracking-[0.2em] text-silver/50 uppercase font-bold">SYSTEM: ACTIVE</span>
            </div>
            <p class="font-display text-2xl font-bold text-white tracking-tight">0.4s <span class="text-silver/40 text-sm ml-1 font-medium">LCP</span></p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Perspective Ambient Overlay -->
  <div class="absolute inset-0 pointer-events-none z-[5] bg-gradient-to-t from-black via-transparent to-black opacity-80"></div>

</section>

<script>
  import gsap from 'gsap';

  document.addEventListener('astro:page-load', () => {
    const hero = document.querySelector('.hero-section');
    if (!hero) return;

    const tl = gsap.timeline({
      defaults: { ease: "expo.out" }
    });

    gsap.set('.hero-mask', { scaleY: 1, originY: 0 });

    tl.to('.scan-line', {
      opacity: 1,
      duration: 0.2
    })
    .to('.scan-line', {
      top: '100%',
      duration: 1.8,
      ease: "power4.inOut"
    }, "start")
    .to('.hero-mask', {
      scaleY: 0,
      duration: 1.8,
      ease: "power4.inOut"
    }, "start")
    .to('.hero-radar', {
      opacity: 0.5,
      duration: 1.5,
      ease: "power2.inOut"
    }, "start+=0.4")
    .to('.badge-reveal', {
      y: 0,
      duration: 1.2
    }, "start+=0.8")
    .to('.headline-reveal', {
      y: 0,
      stagger: 0.08,
      duration: 1.5
    }, "start+=1")
    .to('.text-reveal', {
      y: 0,
      duration: 1.2
    }, "start+=1.3")
    .to('.cta-reveal', {
      y: 0,
      duration: 1.2
    }, "start+=1.5")
    .to('.stats-reveal', {
      opacity: 1,
      x: 0,
      stagger: 0.15,
      duration: 1
    }, "start+=1.8")
    .to('.scan-line', {
      opacity: 0,
      duration: 0.4
    });

    tl.set('.scan-line', { display: 'none' });
  });
</script>

<style>
  .hero-radar {
    filter: blur(15px);
    transform: scale(1.05);
    transition: filter 2.5s ease-out, transform 2.5s ease-out;
  }
  
  .hero-section:hover .hero-radar {
    filter: blur(0px);
    transform: scale(1);
  }

  /* Optimized character rendering */
  .headline-reveal {
    backface-visibility: hidden;
    -webkit-font-smoothing: antialiased;
  }
</style>
