---
import Badge from '../common/Badge.astro';
import planes from '../../data/planes.json';
---

<section id="planes" class="py-24 md:py-40 bg-black relative border-t border-white/5 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-32 section-header">
      <Badge className="mb-10 text-orange bg-orange/5 border-orange/10">INVERSIONES RENTABLES</Badge>
      <h2 class="font-display font-bold text-5xl md:text-7xl leading-[0.9] tracking-[-0.07em]">
        TU INGRESO A <br/> <span class="text-white italic">LAS GRANDES LIGAS.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch wrap-planes max-w-6xl mx-auto">
      {planes.map(plan => {
        const isCustom = plan.name === 'Marca Multimillonaria';
        const borderColor = plan.recommended ? 'border-white/20' : 'border-[#d6ebfd]/10';

        return (
          <div class={`plan-card relative flex flex-col p-8 md:p-10 rounded-[16px] bg-transparent border ${borderColor} transition-all duration-300 hover:border-[#d6ebfd]/30 group hover:shadow-[rgba(176,199,217,0.145)_0px_0px_0px_1px]`}>
            
            {plan.recommended && (
              <div class="absolute -top-3 left-8 bg-[#11ff99]/10 border border-[#11ff99]/20 text-[#22ff99] text-[10px] uppercase font-semibold tracking-wider py-1 px-3 rounded-full">
                Más popular
              </div>
            )}

            {isCustom && (
              <div class="absolute -top-3 left-8 bg-[#0075ff]/10 border border-[#0075ff]/20 text-[#3b9eff] text-[10px] uppercase font-semibold tracking-wider py-1 px-3 rounded-full">
                Ingeniería de Élite
              </div>
            )}

            <h3 class="font-display font-medium text-xl text-silver mb-2 tracking-[-0.02em]">{plan.name}</h3>
            <div class="flex items-baseline gap-2 mb-10">
              <p class="font-display font-bold text-5xl md:text-6xl text-white tracking-tight">{plan.price}</p>
              {plan.price !== 'Personalizado' && <span class="text-silver/60 text-lg">/proyecto</span>}
            </div>

            <ul class="space-y-5 mb-14 flex-grow">
              {plan.features.map(f => (
                <li class="flex items-start gap-4 group/item">
                  <span class="text-white/30 group-hover/item:text-white transition-colors mt-1">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  </span>
                  <span class="text-silver/80 group-hover/item:text-white transition-colors text-base font-light leading-tight">{f}</span>
                </li>
              ))}
            </ul>

            <div class="mt-auto pt-4 flex">
              <a 
                href="#contacto" 
                class={`inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold tracking-wide transition-all duration-300 w-max ${
                  plan.recommended 
                    ? 'bg-white text-black hover:bg-white/80' 
                    : 'bg-transparent border border-[#d6ebfd]/20 text-white hover:bg-white/10'
                }`}
              >
                Inicia tu estrategia
              </a>
            </div>
          </div>
        )
      })}
    </div>
  </div>
</section>
