---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Hero from '../components/sections/Hero.astro';
import Nosotros from '../components/sections/Nosotros.astro';
import Servicios from '../components/sections/Servicios.astro';
import Proceso from '../components/sections/Proceso.astro';
import Proyectos from '../components/sections/Proyectos.astro';
import Contacto from '../components/sections/Contacto.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout>
  <Navbar />
  
  <main>
    <Hero />
    <Nosotros />
    <Servicios />
    <Proceso />
    <Proyectos />
    <Contacto />
  </main>
  
  <Footer />
</Layout>

<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

document.addEventListener('astro:page-load', () => {
  gsap.registerPlugin(ScrollTrigger);

  // 1. Hero Animations - Handled inside Hero component for immediate feel
  
  // 2. Nosotros Reveal
  gsap.fromTo('.nosotros-reveal', 
    { y: 60, autoAlpha: 0 },
    {
      scrollTrigger: {
        trigger: '#nosotros',
        start: 'top 80%',
      },
      y: 0,
      autoAlpha: 1,
      duration: 1.2,
      ease: "power3.out"
    }
  );

  gsap.fromTo('.nosotros-stats > div', 
    { y: 40, autoAlpha: 0 },
    {
      scrollTrigger: {
        trigger: '.nosotros-stats',
        start: 'top 85%'
      },
      y: 0,
      autoAlpha: 1,
      duration: 1,
      stagger: 0.2,
      ease: "expo.out"
    }
  );

  // 3. Servicios Grid
  gsap.fromTo('.servicio-card', 
    { y: 80, autoAlpha: 0 },
    {
      scrollTrigger: {
        trigger: '#servicios',
        start: 'top 75%'
      },
      y: 0,
      autoAlpha: 1,
      duration: 1,
      stagger: 0.15,
      ease: "power4.out"
    }
  );

  // 4. Proceso Timeline
  const tlProceso = gsap.timeline({
    scrollTrigger: {
      trigger: '.wrap-proceso',
      start: 'top 70%',
      end: 'bottom bottom',
    }
  });

  tlProceso.fromTo('.timeline-line', 
    { scaleY: 0 },
    { scaleY: 1, duration: 1.5, ease: "none" }
  );

  gsap.fromTo('.timeline-item', 
    { y: 40, autoAlpha: 0 },
    {
      scrollTrigger: {
        trigger: '.wrap-proceso',
        start: 'top 75%',
      },
      y: 0,
      autoAlpha: 1,
      duration: 1,
      stagger: 0.2,
      ease: "power3.out"
    }
  );

  // 5. Planes cards
  gsap.fromTo('.plan-card', 
    { y: 60, autoAlpha: 0, scale: 0.95 },
    {
      scrollTrigger: {
        trigger: '.wrap-planes',
        start: 'top 80%'
      },
      y: 0,
      autoAlpha: 1,
      scale: 1,
      duration: 1.2,
      stagger: 0.2,
      ease: "expo.out"
    }
  );

  // Global refresh for any late-loading images
  window.addEventListener('load', () => {
    // Retrasar el refresh de GSAP usando setTimeout y rAF para evitar el TBT inicial
    setTimeout(() => {
      requestAnimationFrame(() => ScrollTrigger.refresh());
    }, 500);
  });
});
</script>
