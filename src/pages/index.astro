---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Hero from '../components/sections/Hero.astro';
import Nosotros from '../components/sections/Nosotros.astro';
import Servicios from '../components/sections/Servicios.astro';
import Proceso from '../components/sections/Proceso.astro';
import Planes from '../components/sections/Planes.astro';
import Contacto from '../components/sections/Contacto.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout>
  <Navbar />
  
  <main>
    <Hero />
    <Nosotros />
    <Servicios />
    <Proceso />
    <Planes />
    <Contacto />
  </main>
  
  <Footer />
</Layout>

<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

document.addEventListener('astro:page-load', () => {
  gsap.registerPlugin(ScrollTrigger);

  // 1. Hero Animations
  gsap.to('[data-gsap="hero-elem"]', {
    y: 0,
    opacity: 1,
    duration: 1,
    stagger: 0.15,
    ease: "power3.out"
  });

  // 2. Nosotros Reveal
  gsap.from('.nosotros-reveal', {
    scrollTrigger: {
      trigger: '#nosotros',
      start: 'top 75%'
    },
    y: 40,
    opacity: 0,
    duration: 0.8,
    ease: "power2.out"
  });

  gsap.from('.nosotros-stats > div', {
    scrollTrigger: {
      trigger: '.nosotros-stats',
      start: 'top 85%'
    },
    y: 30,
    opacity: 0,
    duration: 0.8,
    stagger: 0.2,
    ease: "back.out(1.2)"
  });

  // 3. Servicios Grid
  gsap.from('.servicio-card', {
    scrollTrigger: {
      trigger: '#servicios',
      start: 'top 70%'
    },
    y: 50,
    opacity: 0,
    duration: 0.7,
    stagger: 0.1,
    ease: "power2.out"
  });

  // 4. Proceso Timeline
  const tlProceso = gsap.timeline({
    scrollTrigger: {
      trigger: '.wrap-proceso',
      start: 'top 60%',
      end: 'bottom bottom',
    }
  });

  tlProceso.to('.timeline-line', {
    scaleY: 1,
    duration: 1.5,
    ease: "none"
  });

  gsap.to('.timeline-item', {
    scrollTrigger: {
      trigger: '.wrap-proceso',
      start: 'top 70%',
    },
    y: 0,
    opacity: 1,
    duration: 0.8,
    stagger: 0.2,
    ease: "power2.out"
  });

  // 5. Planes cards
  gsap.from('.plan-card', {
    scrollTrigger: {
      trigger: '.wrap-planes',
      start: 'top 75%'
    },
    y: 40,
    opacity: 0,
    scale: 0.95,
    duration: 0.6,
    stagger: 0.15,
    ease: "power2.out"
  });
});
</script>
