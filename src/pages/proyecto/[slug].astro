---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import Badge from '../../components/common/Badge.astro';
import data from '../../data/proyectos.json';
import { ImageAutoSlider } from '../../components/ui/ImageAutoSlider';

interface StackItem {
  name: string;
  desc: string;
}

interface StackCategory {
  category: string;
  items: StackItem[];
}

interface ProcessStep {
  step: number;
  title: string;
  duration: string;
  desc: string;
  deliverables: string[];
}

interface Proyecto {
  id: string;
  tag: string;
  duration: string;
  teamSize: string;
  color: string;
  name: string;
  desc: string;
  heroImage: string;
  challenge: string;
  solution: string;
  results: string[];
  stack: StackCategory[];
  process: ProcessStep[];
  features: string[];
  gallery: string[];
}

export async function getStaticPaths() {
  return data.proyectos.map((proyecto) => ({
    params: { slug: proyecto.id },
    props: { proyecto },
  }));
}

const { proyecto } = Astro.props as { proyecto: Proyecto };
---

<Layout title={`${proyecto.name} | One Out Solutions`} description={proyecto.desc}>
  <Navbar />

  <main class="bg-black text-white selection:bg-orange selection:text-white pt-24">
    <!-- Hero Header -->
    <header class="max-w-7xl mx-auto px-6 pt-8 md:pt-16 pb-12 relative z-10">
      
      <div class="mb-12">
        <a href="/#proyectos" class="inline-flex items-center gap-2 text-silver hover:text-orange transition-colors duration-300 font-display text-sm tracking-widest uppercase mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          Volver a Proyectos
        </a>
      </div>

      <div class="flex flex-wrap items-center gap-4 md:gap-6 mb-8 text-sm md:text-base font-display text-silver">
        <Badge className="border-orange/20 text-orange bg-orange/10">
          {proyecto.tag}
        </Badge>
        
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          <span class="tracking-wide">{proyecto.duration}</span>
        </div>
        
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          <span class="tracking-wide">{proyecto.teamSize}</span>
        </div>
      </div>

      <h1 class="font-display font-bold text-5xl md:text-7xl lg:text-[5rem] leading-[1.05] tracking-[-0.04em] mb-6 max-w-4xl text-white">
        {proyecto.name}
      </h1>

      <p class="text-xl md:text-2xl text-silver font-light max-w-3xl leading-relaxed">
        {proyecto.desc}
      </p>
    </header>

    <!-- Hero Image -->
    <section class="max-w-7xl mx-auto px-6 mb-24 md:mb-40 project-hero-img opacity-0">
      <div class="relative rounded-2xl md:rounded-4xl overflow-hidden border border-[#d6ebfd]/19 bg-black shadow-[0_0_0_1px_rgba(176,199,217,0.145)]">
        <img 
          src={proyecto.heroImage} 
          alt={`Imagen representativa del proyecto ${proyecto.name}`} 
          class="w-full h-auto object-cover object-center max-h-[80vh]" 
          width="1280"
          height="720"
          decoding="sync"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-transparent pointer-events-none"></div>
      </div>
    </section>

    <!-- Content Sections -->
    <div class="max-w-6xl mx-auto px-6 gap-y-32 flex flex-col pb-32">

      <!-- Resumen: Desafío vs Solución -->
      <section class="scroll-anim opacity-0 translate-y-8">
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-6 text-white tracking-[-0.05em]">Resumen del Proyecto</h2>
        <p class="text-lg md:text-xl text-silver mb-16 max-w-4xl leading-relaxed">
          {proyecto.desc}
        </p>

        <div class="grid md:grid-cols-2 gap-12 md:gap-20">
          <div>
            <h3 class="font-display text-3xl font-bold mb-6 text-orange tracking-[-0.05em]">El Desafío</h3>
            <p class="text-silver text-lg leading-relaxed">
              {proyecto.challenge}
            </p>
          </div>
          <div>
            <h3 class="font-display text-3xl font-bold mb-6 text-orange tracking-[-0.05em]">La Solución</h3>
            <p class="text-silver text-lg leading-relaxed">
              {proyecto.solution}
            </p>
          </div>
        </div>
      </section>

      <!-- Resultados -->
      <section class="scroll-anim opacity-0 translate-y-8">
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-10 text-white tracking-[-0.05em]">Resultados Obtenidos</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {proyecto.results.map((res: string) => (
            <div class="bg-black border border-[#d6ebfd]/19 p-6 rounded-xl flex items-start gap-4">
              <svg class="text-orange shrink-0 mt-1" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <p class="text-[#f0f0f0] md:text-lg">{res}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Stack -->
      <section class="scroll-anim opacity-0 translate-y-8">
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-12 text-white tracking-[-0.05em]">Stack Tecnológico</h2>
        <div class="flex flex-col gap-12">
          {proyecto.stack.map((category: StackCategory) => (
            <div>
              <h3 class="text-xl font-bold text-orange mb-6 tracking-tight">{category.category}</h3>
              <div class="grid md:grid-cols-2 gap-6">
                {category.items.map((item: StackItem) => (
                  <div class="bg-black border border-[#d6ebfd]/19 p-6 md:p-8 rounded-xl transition-colors hover:border-[#3b9eff]">
                    <h4 class="font-display font-bold text-xl md:text-2xl mb-2 text-[#f0f0f0]">{item.name}</h4>
                    <p class="text-silver">{item.desc}</p>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Proceso -->
      <section class="scroll-anim opacity-0 translate-y-8">
        <div class="flex items-center gap-4 mb-12">
          <svg class="text-orange" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"></path><path d="m17 5-5-3-5 3"></path><path d="m19 19-7 3-7-3"></path><path d="M22 12h-4"></path><path d="M6 12H2"></path></svg>
          <h2 class="font-display text-4xl md:text-5xl font-bold text-white tracking-[-0.05em]">Proceso de Desarrollo</h2>
        </div>

        <div class="relative ml-4 md:ml-8 border-l border-[#d6ebfd]/19 flex flex-col gap-16 pb-8">
          {proyecto.process.map((step: ProcessStep) => (
            <div class="relative pl-10 md:pl-16">
              <!-- Timeline Dot -->
              <span class="absolute -left-1.25 top-2 w-2.25 h-2.25 rounded-full bg-orange shadow-[0_0_10px_2px_rgba(255,128,31,0.5)]"></span>
              
              <div class="flex flex-wrap items-center gap-4 mb-4">
                <h3 class="font-display font-bold text-2xl md:text-3xl text-white">
                  {step.step}. {step.title}
                </h3>
                <span class="px-4 py-1 text-xs font-bold tracking-widest uppercase border border-orange/20 text-orange rounded-full bg-orange/5">
                  {step.duration}
                </span>
              </div>
              
              <p class="text-silver text-lg mb-6 leading-relaxed max-w-3xl">
                {step.desc}
              </p>

              <div>
                <h4 class="text-silver/60 uppercase tracking-widest text-sm font-bold mb-4">Entregables:</h4>
                <ul class="grid md:grid-cols-2 gap-4">
                  {step.deliverables.map((item: string) => (
                    <li class="flex items-start gap-3">
                      <span class="text-orange text-xl leading-none mt-1">&bull;</span>
                      <span class="text-[#f0f0f0]">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Características -->
      <section class="scroll-anim opacity-0 translate-y-8">
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-10 text-white tracking-[-0.05em]">Características Principales</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {proyecto.features.map((feature: string) => (
            <div class="bg-black border border-[#d6ebfd]/19 py-4 px-6 rounded-lg text-[#f0f0f0] hover:bg-black hover:border-orange/50 transition-colors flex items-start gap-3">
              <span class="text-orange/50">—</span>
              {feature}
            </div>
          ))}
        </div>
      </section>

      <!-- Galería si existe -->
      {proyecto.gallery && proyecto.gallery.length > 0 && (
        <section class="scroll-anim opacity-0 translate-y-8 overflow-hidden w-screen relative left-1/2 -translate-x-1/2">
          <div class="max-w-6xl mx-auto px-6 mb-10">
            <h2 class="font-display text-4xl md:text-5xl font-bold text-white tracking-[-0.05em]">Galería</h2>
          </div>
          <ImageAutoSlider client:visible images={proyecto.gallery} />
        </section>
      )}
    </div>

    <!-- Call to action block -->
    <section class="py-24 border-t border-white/10 text-center relative overflow-hidden bg-black">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,var(--tw-gradient-stops))] from-cyan/10 via-black to-black pointer-events-none"></div>
      <div class="max-w-2xl mx-auto px-6 relative z-10">
        <h2 class="font-display font-bold text-4xl md:text-5xl text-white mb-6">¿Inspirado por este proyecto?</h2>
        <p class="text-white/60 text-xl mb-10">Trabajemos juntos para llevar tu sistema al siguiente nivel.</p>
        <a 
          href="/#contacto" 
          class="inline-block bg-orange text-white font-bold tracking-widest uppercase text-sm px-8 py-4 rounded-md border border-orange hover:bg-black hover:text-orange transition-all duration-300"
        >
          Iniciar Cotización
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  document.addEventListener('astro:page-load', () => {
    gsap.registerPlugin(ScrollTrigger);

    // Hero image animation
    gsap.to('.project-hero-img', {
      y: 0,
      opacity: 1,
      duration: 1.2,
      ease: 'power3.out',
      delay: 0.2
    });

    // Content reveal animations
    gsap.utils.toArray('.scroll-anim').forEach((elem: any) => {
      gsap.to(elem, {
        scrollTrigger: {
          trigger: elem,
          start: 'top 85%',
        },
        y: 0,
        opacity: 1,
        duration: 0.8,
        ease: 'power2.out',
      });
    });
  });
</script>

<style>
/* Adjust bullet point rendering cleanly */
ul li span:first-child {
  transform: translateY(-0.1rem);
}
</style>