---
import { ClientRouter } from 'astro:transitions';
import '@fontsource-variable/outfit';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "One Out Solutions | Desarrollo de software", 
  description = "Soluciones tecnológicas empresariales en Costa Rica. Desarrollo a medida, sistemas escalables y diseño UX." 
} = Astro.props;
---

<!doctype html>
<html lang="es" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site || "https://oneoutsolutions.com")} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.toString()} />
    <meta property="og:site_name" content="One Out Solutions" />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site ?? 'https://oneoutsolutions.com').toString()} />
    
    <ClientRouter />
    
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "One Out Solutions",
        "url": "https://oneoutsolutions.com",
        "logo": "https://oneoutsolutions.com/favicon.svg",
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+506-0000-0000",
          "contactType": "customer service",
          "areaServed": "CR",
          "availableLanguage": "Spanish"
        }
      }
    </script>
    <script type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "wgueh56bvy");
</script>
  </head>
  <body class="bg-black text-white selection:bg-orange selection:text-white antialiased overflow-x-hidden min-h-screen flex flex-col">
    <slot />
    
    <!-- Botón Volver Arriba -->
    <button 
      id="scrollToTopBtn" 
      aria-label="Volver al inicio"
      class="fixed bottom-6 right-6 md:bottom-10 md:right-10 w-12 h-12 flex items-center justify-center rounded-full bg-black/50 backdrop-blur-md border border-white/20 text-white/70 hover:text-orange hover:border-orange hover:bg-orange/10 transition-all duration-500 z-100 opacity-0 translate-y-8 pointer-events-none group"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-y-1 transition-transform duration-300">
        <path d="m18 15-6-6-6 6"/>
      </svg>
    </button>

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import Lenis from 'lenis';

      gsap.registerPlugin(ScrollTrigger);

      ScrollTrigger.config({ ignoreMobileResize: true });

      let lenis: InstanceType<typeof Lenis> | null = null;

      document.addEventListener('astro:before-preparation', () => {
        if (lenis) {
          lenis.destroy();
          lenis = null;
        }
        ScrollTrigger.getAll().forEach((t) => t.kill());
      });

      document.addEventListener('astro:page-load', () => {
        lenis = new Lenis({
          duration: 1.2,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          orientation: 'vertical',
          gestureOrientation: 'vertical',
          smoothWheel: true,
          wheelMultiplier: 1,
          touchMultiplier: 2,
        });

        lenis.on('scroll', ScrollTrigger.update);

        const scrollToTopBtn = document.getElementById('scrollToTopBtn');
        if (scrollToTopBtn) {
          lenis.on('scroll', () => {
            const currentScroll = window.scrollY || document.documentElement.scrollTop;
            if (currentScroll > 600) {
              scrollToTopBtn.classList.remove('opacity-0', 'translate-y-8', 'pointer-events-none');
              scrollToTopBtn.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
            } else {
              scrollToTopBtn.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none');
              scrollToTopBtn.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
            }
          });

          scrollToTopBtn.addEventListener('click', () => {
            lenis!.scrollTo(0, { duration: 1.5, easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
          });
        }

        gsap.ticker.add((time) => {
          lenis!.raf(time * 1000);
        });

        gsap.ticker.lagSmoothing(0);
      });
    </script>
  </body>
</html>
