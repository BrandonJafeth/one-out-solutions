---
import { ClientRouter } from 'astro:transitions';
import '@fontsource-variable/outfit';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "One Out Solutions | Desarrollo de software", 
  description = "Soluciones tecnológicas empresariales en Costa Rica. Desarrollo a medida, sistemas escalables y diseño UX." 
} = Astro.props;
---

<!doctype html>
<html lang="es" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site || "https://oneoutsolutions.com")} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content="One Out Solutions" />
    
    <ClientRouter />
    
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "One Out Solutions",
        "url": "https://oneoutsolutions.com",
        "logo": "https://oneoutsolutions.com/favicon.svg",
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+506-0000-0000",
          "contactType": "customer service",
          "areaServed": "CR",
          "availableLanguage": "Spanish"
        }
      }
    </script>
  </head>
  <body class="bg-black text-white selection:bg-orange selection:text-white antialiased overflow-x-hidden min-h-screen flex flex-col">
    <slot />
    
    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import Lenis from 'lenis';

      gsap.registerPlugin(ScrollTrigger);

      // Define a custom setup on Astro page transitions
      document.addEventListener('astro:page-load', () => {
        // Inicializar Smooth Scroll con Lenis
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          orientation: 'vertical',
          gestureOrientation: 'vertical',
          smoothWheel: true,
          wheelMultiplier: 1,
          touchMultiplier: 2,
        });

        // Sincronizar Lenis con GSAP ScrollTrigger
        lenis.on('scroll', ScrollTrigger.update);

        gsap.ticker.add((time) => {
          lenis.raf(time * 1000);
        });

        gsap.ticker.lagSmoothing(0);

        // Defer refresh to avoid layout thrashing synchronously on mount
        requestAnimationFrame(() => {
          ScrollTrigger.refresh();
        });
      });
    </script>
  </body>
</html>
